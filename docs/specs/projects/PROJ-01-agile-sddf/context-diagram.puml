@startuml C4Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Agile SDDF — Diagrama de Contexto (C4 Nivel 1)

Person(usuario, "Developer / PM / Arquitecto", "Builder, freelancer o miembro de equipo ágil que usa el framework para especificar proyectos software con IA.")

System(sddf, "Agile SDDF", "Framework & Harness multiagente minimalista que automatiza el ciclo completo de especificación de proyectos software usando archivos Markdown como agentes, skills y templates.")

System_Ext(claude_api, "Agentic AI coding assistant", "Runtime de IA primario que ejecuta los agentes y skills del framework (Github Copilot, Claude Code, Open Code, etc.).")
System_Ext(github, "GitHub", "Repositorio de código y artefactos de especificación. Gestión de branches y publicación del paquete npm.")
System_Ext(openspec_cli, "SDD CLI", "Herramienta de línea de comandos para gestión del ciclo de vida de cambios spec-driven (OpenSpec, Speckit).")
System_Ext(npm_registry, "npm Registry", "Registro público desde donde se instala el framework globalmente o por proyecto.")

Rel(usuario, sddf, "Invoca skills, revisa y aprueba artefactos generados", "CLI / Chat")
Rel(sddf, claude_api, "Delega ejecución de agentes y generación de contenido", "API REST / HTTPS")
Rel(sddf, github, "Versiona artefactos de especificación y publica releases del paquete", "Git / HTTPS")
Rel(sddf, openspec_cli, "Gestiona cambios spec-driven: new, status, apply, archive", "CLI / Node.js")
Rel(npm_registry, sddf, "Provee distribución del paquete para instalación global o local", "npm / HTTPS")

@enduml